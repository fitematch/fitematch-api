# Host port bound to the API container:
APPLICATION_BIND_PORT=3000

# API container port:
APPLICATION_PORT=3000

# JWT secret used to sign access tokens:
JWT_SECRET=dev-secret-change-me

# JWT secret used to sign refresh tokens:
JWT_REFRESH_SECRET=refresh-secret-change-me

# JWT access token expiration time (e.g., '1d' for 1 day, '2h' for 2 hours):
JWT_EXPIRES_IN=1d

# JWT refresh token expiration time (e.g., '7d' for 7 days, '1m' for 1 month):
JWT_REFRESH_EXPIRES_IN=7d

# MongoDB database URI:
DATABASE_URI=mongodb://database:27017/fitematch

# MongoDB database schema:
DATABASE_NAME=fitematch

# MongoDB host bind port:
DATABASE_BIND_PORT=27017

# MongoDB container port:
DATABASE_PORT=27017

# Email provider driver:
EMAIL_PROVIDER_DRIVER=mailtrap

# Mailtrap Sandbox SMTP host:
MAILTRAP_HOST=sandbox.smtp.mailtrap.io

# Mailtrap Sandbox SMTP port:
MAILTRAP_PORT=2525

# Mailtrap Sandbox SMTP username:
MAILTRAP_USER=change-me

# Mailtrap Sandbox SMTP password:
MAILTRAP_PASSWORD=change-me

# The email address that will appear as the sender in sandbox emails:
MAILTRAP_SENDER_EMAIL=sandbox@fitematch.local

# The name that will appear as the sender in the emails sent by Mailtrap:
MAILTRAP_SENDER_NAME=fitematch Team

# Activation code expiration time in minutes:
ACTIVATION_CODE_EXPIRES_IN_MINUTES=60

# Storage driver:
STORAGE_DRIVER=local

# Local storage root path:
LOCAL_STORAGE_ROOT_PATH=public/uploads

# Local storage public URL prefix:
LOCAL_STORAGE_PUBLIC_URL=/uploads

# AWS S3 bucket:
AWS_S3_BUCKET=

# AWS S3 region:
AWS_S3_REGION=

# AWS S3 access key ID:
AWS_S3_ACCESS_KEY_ID=

# AWS S3 secret access key:
AWS_S3_SECRET_ACCESS_KEY=

# AWS S3 public URL:
AWS_S3_PUBLIC_URL=

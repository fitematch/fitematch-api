# Host port bound to the API container:
APPLICATION_BIND_PORT=3000

# API container port:
APPLICATION_PORT=3000

# JWT secret used to sign access tokens:
JWT_SECRET=dev-secret-change-me

# JWT secret used to sign refresh tokens:
JWT_REFRESH_SECRET=refresh-secret-change-me

# JWT access token expiration time (e.g., '1d' for 1 day, '2h' for 2 hours):
JWT_EXPIRES_IN=1d

# JWT refresh token expiration time (e.g., '7d' for 7 days, '1m' for 1 month):
JWT_REFRESH_EXPIRES_IN=7d

# MongoDB database URI:
DATABASE_URI=mongodb://database:27017/fitematch

# MongoDB database schema:
DATABASE_NAME=fitematch

# MongoDB host bind port:
DATABASE_BIND_PORT=27017

# MongoDB container port:
DATABASE_PORT=27017
